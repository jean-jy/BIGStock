{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role in the system." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["displayName", "email", "role"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Represents a medical supply or equipment item.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the item." },
        "subtext": { "type": "string", "description": "Additional details (e.g., material)." },
        "category": { "type": "string", "description": "Category of the item." },
        "sku": { "type": "string", "description": "Unique SKU code." },
        "total": { "type": "integer", "description": "Current global stock quantity." },
        "unit": { "type": "string", "description": "Unit of measurement (e.g., Boxes)." },
        "status": { "type": "string", "enum": ["REORDER", "HEALTHY", "BALANCED"], "description": "Stock status." },
        "lastAudit": { "type": "string", "format": "date-time", "description": "Last audit timestamp." }
      },
      "required": ["name", "category", "sku", "total", "status"]
    },
    "Branch": {
      "title": "Branch",
      "description": "Represents a clinic branch.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the branch." },
        "location": { "type": "string", "description": "Physical location or address." },
        "manager": { "type": "string", "description": "Name of the branch manager." }
      },
      "required": ["name", "location"]
    },
    "BranchInventory": {
      "title": "Branch Inventory",
      "description": "Tracks stock quantity for a specific item at a specific branch.",
      "type": "object",
      "properties": {
        "branchId": { "type": "string", "description": "ID of the branch." },
        "itemId": { "type": "string", "description": "ID of the inventory item." },
        "quantity": { "type": "integer", "description": "Current stock at this branch." }
      },
      "required": ["branchId", "itemId", "quantity"]
    },
    "TransferRequest": {
      "title": "Transfer Request",
      "description": "A request to move stock from one branch to another.",
      "type": "object",
      "properties": {
        "fromBranchId": { "type": "string", "description": "Source branch ID." },
        "toBranchId": { "type": "string", "description": "Destination branch ID." },
        "itemId": { "type": "string", "description": "ID of the item being transferred." },
        "quantity": { "type": "integer", "description": "Quantity to transfer." },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED", "COMPLETED"], "description": "Current status of the request." },
        "requestedBy": { "type": "string", "description": "UID of the user who made the request." },
        "requestedAt": { "type": "string", "format": "date-time", "description": "When the request was made." },
        "processedBy": { "type": "string", "description": "UID of the user who approved/rejected the request." },
        "processedAt": { "type": "string", "format": "date-time", "description": "When the request was processed." }
      },
      "required": ["fromBranchId", "toBranchId", "itemId", "quantity", "status", "requestedBy", "requestedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Global inventory items."
    },
    "/branches/{branchId}": {
      "schema": "Branch",
      "description": "Clinic branches."
    },
    "/branches/{branchId}/inventory/{itemId}": {
      "schema": "BranchInventory",
      "description": "Inventory levels per branch."
    },
    "/transfers/{transferId}": {
      "schema": "TransferRequest",
      "description": "Stock transfer requests."
    }
  }
}
